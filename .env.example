# ===========================================================================
# PulseGrid Predictive Maintenance Platform — Environment Configuration
# ===========================================================================
# Copy this file to .env and adjust values for your environment.
# All values have sensible defaults for local development.
# ===========================================================================

# --- Database ---
# SQLite (default for local dev). For production, use PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/pulsegrid
DATABASE_URL=sqlite:///backend/iot_data.db

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# --- Data Retention ---
# Sensor data and resolved alerts older than this are eligible for cleanup
DATA_RETENTION_DAYS=30

# --- Rate Limiting ---
# Maximum sensor ingestion requests per machine per second
RATE_LIMIT_PER_SECOND=10

# --- ML Model ---
# Path to the trained model. Relative to the project root.
ML_MODEL_PATH=ml/model.joblib

# --- Dataset ---
# Path to the active CSV dataset
DATASET_PATH=dataset/ai4i2020.csv
